# Copia questo file in ".env" e modifica i valori.
# Il file ".env" NON va mai condiviso o messo su GitHub (contiene segreti).

# Password per entrare nel sito (la usi tu E il tuo amico).
SITE_PASSWORD=e25gtoqy

# Deve essere IDENTICO al campo "agentSecret" in agent-win/config.json
AGENT_SECRET=w8yh7gs9fbvz602c

# Cartella dove metti i giochi. Ogni sottocartella con un .exe dentro
# diventa una scheda nella libreria.
GAMES_DIR=C:\games

# Porta del sito
PORT=3000

# Ogni quanto ri-scansionare GAMES_DIR (in millisecondi). 300000 = 5 minuti.
SCAN_INTERVAL_MS=300000
